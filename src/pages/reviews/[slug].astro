---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import RelatedContent from '../../components/RelatedContent.astro';
import ReviewCTA from '../../components/ReviewCTA.astro';
import NewsletterSignup from '../../components/NewsletterSignup.astro';

export async function getStaticPaths() {
  const reviews = await getCollection('reviews');
  return reviews.map((review) => ({
    params: { slug: review.slug },
    props: { review },
  }));
}

const { review } = Astro.props;
const { Content } = await review.render();
const { title, description, pubDate, updatedDate, productName, rating, pros, cons, pricing, bestFor, affiliateUrl } = review.data;
const formattedPub = pubDate.toISOString().slice(0, 10);
const formattedUpd = updatedDate?.toISOString().slice(0, 10);

// Skip top CTA for comparison/review vs review pages (no single product)
const isComparison = !!review.slug.match(/vs|-vs-/);
---

<BaseLayout title={title} description={description}>
  <h1>{title}</h1>
  <p class="meta">Published {formattedPub}{formattedUpd && ` · Updated ${formattedUpd}`}</p>

  {!isComparison && rating && affiliateUrl && (
    <ReviewCTA
      productName={productName}
      affiliateUrl={affiliateUrl}
      rating={rating}
      pricing={pricing}
      bestFor={bestFor}
      variant="top"
      source="top-banner"
    />
  )}

  <Content />

  <h2>Quick pros and cons</h2>
  <h3>What we like</h3>
  <ul>
    {pros.map((p) => <li>{p}</li>)}
  </ul>
  <h3>What we don't</h3>
  <ul>
    {cons.map((c) => <li>{c}</li>)}
  </ul>

  {!isComparison && affiliateUrl && (
    <ReviewCTA
      productName={productName}
      affiliateUrl={affiliateUrl}
      pricing={pricing}
      bestFor={bestFor}
      variant="footer"
      source="footer-card"
    />
  )}

  <NewsletterSignup variant="inline" />

  <RelatedContent
    currentSlug={review.slug}
    currentCollection="reviews"
    mentionedProducts={[productName]}
  />

  <p><a href="/reviews/">← Back to all reviews</a></p>
</BaseLayout>
