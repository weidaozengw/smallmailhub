---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import RelatedContent from '../../components/RelatedContent.astro';
import ReviewCTA from '../../components/ReviewCTA.astro';
import NewsletterSignup from '../../components/NewsletterSignup.astro';

export async function getStaticPaths() {
  const reviews = await getCollection('reviews');
  return reviews.map((review) => ({
    params: { slug: review.slug },
    props: { review },
  }));
}

const { review } = Astro.props;
const { Content } = await review.render();
const { title, description, pubDate, updatedDate, productName, rating, pros, cons, pricing, bestFor, affiliateUrl } = review.data;
const formattedPub = pubDate.toISOString().slice(0, 10);
const formattedUpd = updatedDate?.toISOString().slice(0, 10);

// Skip top CTA for comparison/review vs review pages (no single product)
const isComparison = !!review.slug.match(/vs|-vs-/);

// Map productName → PNG file slug (lowercase, no spaces). Falls back to 'default' if PNG doesn't exist.
const possibleSlug = productName ? productName.toLowerCase().replace(/[^a-z0-9]/g, '') : null;
// List of PNGs that exist in /public/og/ — used to gracefully fall back
const knownOgSlugs = ['mailerlite', 'convertkit', 'brevo', 'mailchimp', 'activecampaign', 'hubspot', 'klaviyo', 'sendgrid', 'aweber', 'beehiiv', 'constantcontact', 'getresponse', 'kit', 'mailjet', 'moosend', 'omnisend', 'sendlane', 'mailchimpvsmailerlite', 'convertkitvsmailerlite', 'brevsvsmailchimp', 'moosendvsmailerlite', 'klaviyovs'];
const ogImageSlug = possibleSlug && knownOgSlugs.includes(possibleSlug) ? possibleSlug : 'default';
---

<BaseLayout title={title} description={description} ogImage={ogImageSlug}>

  {/* Schema.org structured data for rich snippets in Google search */}
  {!isComparison && rating && productName && (
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Review',
      name: title,
      reviewBody: description,
      datePublished: formattedPub,
      dateModified: formattedUpd || formattedPub,
      author: { '@type': 'Organization', name: 'MailPilot', url: 'https://smallmailhub.com' },
      publisher: { '@type': 'Organization', name: 'MailPilot', url: 'https://smallmailhub.com' },
      itemReviewed: {
        '@type': 'SoftwareApplication',
        name: productName,
        applicationCategory: 'BusinessApplication',
        operatingSystem: 'Web',
        offers: pricing ? { '@type': 'Offer', description: pricing, url: affiliateUrl } : undefined,
      },
      reviewRating: {
        '@type': 'Rating',
        ratingValue: rating,
        bestRating: 5,
        worstRating: 1,
      },
      url: new URL(Astro.url.pathname, Astro.site).toString(),
    })} />
  )}

  {isComparison && (
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Article',
      headline: title,
      description: description,
      datePublished: formattedPub,
      dateModified: formattedUpd || formattedPub,
      author: { '@type': 'Organization', name: 'MailPilot', url: 'https://smallmailhub.com' },
      publisher: { '@type': 'Organization', name: 'MailPilot', url: 'https://smallmailhub.com' },
      url: new URL(Astro.url.pathname, Astro.site).toString(),
    })} />
  )}

  <h1>{title}</h1>
  <p class="meta">Published {formattedPub}{formattedUpd && ` · Updated ${formattedUpd}`} · Last reviewed {new Date().toISOString().slice(0, 10)}</p>

  {!isComparison && rating && affiliateUrl && (
    <ReviewCTA
      productName={productName}
      affiliateUrl={affiliateUrl}
      rating={rating}
      pricing={pricing}
      bestFor={bestFor}
      variant="top"
      source="top-banner"
    />
  )}

  <Content />

  <h2>Quick pros and cons</h2>
  <h3>What we like</h3>
  <ul>
    {pros.map((p) => <li>{p}</li>)}
  </ul>
  <h3>What we don't</h3>
  <ul>
    {cons.map((c) => <li>{c}</li>)}
  </ul>

  {!isComparison && affiliateUrl && (
    <ReviewCTA
      productName={productName}
      affiliateUrl={affiliateUrl}
      pricing={pricing}
      bestFor={bestFor}
      variant="footer"
      source="footer-card"
    />
  )}

  <NewsletterSignup variant="inline" />

  <RelatedContent
    currentSlug={review.slug}
    currentCollection="reviews"
    mentionedProducts={[productName]}
  />

  <p><a href="/reviews/">← Back to all reviews</a></p>
</BaseLayout>
