---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Contact MailPilot';
const description = 'Get in touch with the MailPilot team — for review suggestions, partnerships, or corrections.';
---

<BaseLayout title={title} description={description}>
  <h1>Contact</h1>
  <p class="meta">Most questions answered below</p>

  <h2>For correction requests</h2>
  <p>Spot a pricing error or outdated feature in one of our reviews? Email us at <strong>hello@smallmailhub.com</strong> with the URL and the correct information. We verify and update within 48 hours.</p>

  <h2>For partnership / advertising inquiries</h2>
  <p>We do not accept payment for reviews. If you're an email marketing vendor and would like us to test an update to your platform, email <strong>partnerships@smallmailhub.com</strong> with details.</p>

  <h2>For everything else</h2>
  <p>Reader questions, content suggestions, "which tool should I pick" — email <strong>hello@smallmailhub.com</strong>. We try to reply within a week.</p>

  <h2>Press kit</h2>
  <p>Logos, screenshots, and our editorial guidelines are available on request. Email <strong>press@smallmailhub.com</strong>.</p>
</BaseLayout>
