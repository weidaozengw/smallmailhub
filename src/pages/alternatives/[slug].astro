---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import RelatedContent from '../../components/RelatedContent.astro';
import ReviewCTA from '../../components/ReviewCTA.astro';
import NewsletterSignup from '../../components/NewsletterSignup.astro';

export async function getStaticPaths() {
  const alts = await getCollection('alternatives');
  return alts.map((alt) => ({
    params: { slug: alt.slug },
    props: { alt },
  }));
}

const { alt } = Astro.props;
const { Content } = await alt.render();
const { title, description, pubDate, replacedProduct, alternatives, affiliateUrl, pricing, bestFor } = alt.data;
const formattedPub = pubDate.toISOString().slice(0, 10);

// 主角 = 第一个 alternative（通常是 top pick）
const topPick = alternatives?.[0];

// OG image mapping for known alternatives pages
const altOgMap: Record<string, string> = {
  'convertkit-alternatives': 'convertkitalts',
  'mailchimp-alternatives': 'mailchimpalts',
  'mailchimp-alternatives-free': 'mailchimpalts',
  'mailchimp-alternatives-for-small-business': 'mailchimpalts',
};
const ogImageSlug = altOgMap[alt.slug] ?? 'default';
---

<BaseLayout title={title} description={description} ogImage={ogImageSlug}>

  {/* Schema.org Article structured data */}
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: title,
    description: description,
    datePublished: formattedPub,
    author: { '@type': 'Organization', name: 'MailPilot', url: 'https://smallmailhub.com' },
    publisher: { '@type': 'Organization', name: 'MailPilot', url: 'https://smallmailhub.com' },
    url: new URL(Astro.url.pathname, Astro.site).toString(),
  })} />

  <h1>{title}</h1>
  <p class="meta">Published {formattedPub}</p>

  {affiliateUrl && topPick && (
    <ReviewCTA
      productName={topPick}
      affiliateUrl={affiliateUrl}
      pricing={pricing}
      bestFor={bestFor}
      variant="top"
      source="alternatives-top"
    />
  )}

  <Content />

  <h2>All alternatives we cover</h2>
  <ul>
    {alternatives.map((a) => <li>{a}</li>)}
  </ul>

  {affiliateUrl && topPick && (
    <ReviewCTA
      productName={topPick}
      affiliateUrl={affiliateUrl}
      pricing={pricing}
      bestFor={bestFor}
      variant="footer"
      source="alternatives-footer"
    />
  )}

  <NewsletterSignup variant="inline" />

  <RelatedContent
    currentSlug={alt.slug}
    currentCollection="alternatives"
    mentionedProducts={alternatives}
  />

  <p><a href="/alternatives/">← Back to all alternatives</a></p>
</BaseLayout>
