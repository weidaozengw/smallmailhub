---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const alts = (await getCollection('alternatives', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);
---

<BaseLayout
  title="Email Marketing Alternatives — MailPilot"
  description="Looking to switch email marketing platforms? Side-by-side alternatives to Mailchimp, ConvertKit, ActiveCampaign, and more."
>
  <h1>Alternatives Guides</h1>
  <p class="meta">{alts.length} guides · Sorted by most recent</p>

  <ul>
    {alts.map((a) => (
      <li><a href={`/alternatives/${a.slug}/`}>{a.data.title}</a></li>
    ))}
  </ul>
</BaseLayout>