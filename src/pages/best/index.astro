---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const lists = (await getCollection('lists', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);
---

<BaseLayout
  title="Best Email Marketing Picks — MailPilot"
  description="Curated best-of lists for every type of small business."
>
  <h1>Best Of Lists</h1>
  <p class="meta">{lists.length} lists</p>

  <ul>
    {lists.map((l) => (
      <li><a href={`/best/${l.slug}/`}>{l.data.title}</a></li>
    ))}
  </ul>
</BaseLayout>