---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import RelatedContent from '../../components/RelatedContent.astro';
import ReviewCTA from '../../components/ReviewCTA.astro';
import NewsletterSignup from '../../components/NewsletterSignup.astro';

export async function getStaticPaths() {
  const lists = await getCollection('lists');
  return lists.map((list) => ({
    params: { slug: list.slug },
    props: { list },
  }));
}

const { list } = Astro.props;
const { Content } = await list.render();
const { title, description, pubDate, items, affiliateUrl, pricing, bestFor } = list.data;
const formattedPub = pubDate.toISOString().slice(0, 10);

// Top pick = 第一个 item（去掉 dash 前的内容）
const topPick = items?.[0]?.split(' — ')[0]?.trim();

// OG image mapping for known best-of pages
const bestOfOgMap: Record<string, string> = {
  'best-email-marketing-tools-for-ecommerce': 'ecommerce',
  'best-email-marketing-tools-for-small-business': 'smallbusiness',
  'best-email-marketing-tools-for-saas': 'saas',
};
const ogImageSlug = bestOfOgMap[list.slug] ?? 'default';
---

<BaseLayout title={title} description={description} ogImage={ogImageSlug}>

  {/* Schema.org Article structured data */}
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: title,
    description: description,
    datePublished: formattedPub,
    author: { '@type': 'Organization', name: 'MailPilot', url: 'https://smallmailhub.com' },
    publisher: { '@type': 'Organization', name: 'MailPilot', url: 'https://smallmailhub.com' },
    url: new URL(Astro.url.pathname, Astro.site).toString(),
  })} />

  {/* ItemList for the ranked tools */}
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: title,
    description: description,
    itemListElement: items?.map((item, idx) => ({
      '@type': 'ListItem',
      position: idx + 1,
      name: item,
    })),
  })} />

  {/* FAQPage schema - auto-generated if content has FAQ section */}
  {(() => {
    const rawBody = list.body || '';
    const faqIdx = rawBody.indexOf('## FAQ');
    if (faqIdx !== -1) {
      const afterFaq = rawBody.substring(faqIdx);
      const sectionMatch = afterFaq.match(/## FAQ\n\n([\s\S]*?)(?=\n## [A-Z]|$)/);
      if (sectionMatch) {
        const inner = sectionMatch[1];
        const qaRegex = /###\s+(.+?)\n\n([\s\S]*?)(?=\n###\s|\n## [A-Z]|$)/g;
        const qaPairs = [];
        let m2;
        while ((m2 = qaRegex.exec(inner)) !== null) {
          qaPairs.push({ question: m2[1].trim(), answer: m2[2].trim() });
        }
        if (qaPairs.length > 0) {
          return (
            <script type="application/ld+json" set:html={JSON.stringify({
              '@context': 'https://schema.org',
              '@type': 'FAQPage',
              mainEntity: qaPairs.map((qa) => ({
                '@type': 'Question',
                name: qa.question,
                acceptedAnswer: { '@type': 'Answer', text: qa.answer },
              })),
            })} />
          );
        }
      }
    }
    return null;
  })()}

  <h1>{title}</h1>
  <p class="meta">Published {formattedPub}</p>

  {affiliateUrl && topPick && (
    <ReviewCTA
      productName={topPick}
      affiliateUrl={affiliateUrl}
      pricing={pricing}
      bestFor={bestFor}
      variant="top"
      source="bestof-top"
    />
  )}

  <Content />

  <h2>Quick picks</h2>
  <ul>
    {items.map((i) => <li>{i}</li>)}
  </ul>

  {affiliateUrl && topPick && (
    <ReviewCTA
      productName={topPick}
      affiliateUrl={affiliateUrl}
      pricing={pricing}
      bestFor={bestFor}
      variant="footer"
      source="bestof-footer"
    />
  )}

  <NewsletterSignup variant="inline" />

  <RelatedContent
    currentSlug={list.slug}
    currentCollection="lists"
    mentionedProducts={items}
  />

  <p><a href="/best/">← Back to all best-of lists</a></p>
</BaseLayout>
