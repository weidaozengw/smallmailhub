---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'You\'re subscribed!';
const description = 'Confirmation page for MailPilot newsletter subscriptions.';
---

<BaseLayout title={title} description={description}>
  <div style="text-align: center; padding: 60px 20px;">
    <h1 style="font-size: 2.2rem; color: #059669;">✓ You're subscribed!</h1>
    <p style="font-size: 1.1rem; color: #475569; max-width: 540px; margin: 16px auto 28px;">
      Thanks for joining. Check your inbox for a confirmation email — and start exploring our top picks while you wait.
    </p>

    <div style="display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; margin-top: 28px;">
      <a href="/best/best-email-marketing-tools-for-small-business/" class="cta" style="background: #2563eb; color: white; padding: 12px 24px; border-radius: 6px; text-decoration: none; font-weight: 600;">
        See our top picks →
      </a>
      <a href="/reviews/" style="background: white; color: #2563eb; padding: 12px 24px; border-radius: 6px; text-decoration: none; font-weight: 600; border: 1px solid #cbd5e1;">
        Browse all reviews
      </a>
    </div>

    <p style="margin-top: 36px; font-size: 0.85rem; color: #94a3b8;">
      Wrong email? <a href="/">Subscribe again</a>
    </p>
  </div>
</BaseLayout>
