---
interface Props {
  /** Variant: 'hero' (large, for homepage), 'inline' (mid-article), 'footer' (compact end-of-page) */
  variant?: 'hero' | 'inline' | 'footer';
  /** Optional headline override */
  headline?: string;
  /** Optional subheadline override */
  subheadline?: string;
  /** Optional incentive text shown below the form */
  incentive?: string;
}

const { variant = 'inline', headline, subheadline, incentive } = Astro.props;

// Default copy per variant
const defaults = {
  hero: {
    headline: 'Get our weekly email marketing tool picks',
    subheadline: 'One short email every Friday. New reviews, deals we found, and what\'s actually changed in the industry. No spam, unsubscribe anytime.',
    incentive: '📩 Join 0+ email marketers who read this every week',
  },
  inline: {
    headline: 'Want more reviews like this?',
    subheadline: 'Get our weekly newsletter — new tool reviews, pricing drops, and the occasional affiliate deal.',
    incentive: 'Free forever · 1-click unsubscribe',
  },
  footer: {
    headline: 'Never miss a review',
    subheadline: 'Weekly email with the latest reviews and deals.',
    incentive: 'No spam',
  },
};

const copy = defaults[variant];
const finalHeadline = headline ?? copy.headline;
const finalSubheadline = subheadline ?? copy.subheadline;
const finalIncentive = incentive ?? copy.incentive;
---

<div class={`newsletter newsletter-${variant}`}>
  <div class="newsletter-text">
    <h3 class="newsletter-headline">{finalHeadline}</h3>
    <p class="newsletter-subheadline">{finalSubheadline}</p>
  </div>
  <form
    class="newsletter-form"
    action="mailto:hello@smallmailhub.com"
    method="POST"
    enctype="text/plain"
    data-cf-form
  >
    <label for={`newsletter-email-${variant}`} class="sr-only">Email address</label>
    <input
      type="email"
      id={`newsletter-email-${variant}`}
      name="email"
      placeholder="your@email.com"
      required
      autocomplete="email"
      class="newsletter-input"
    />
    <input type="hidden" name="source" value={`smallmailhub-${variant}`} />
    <button type="submit" class="newsletter-button">
      {variant === 'hero' ? 'Subscribe free' : 'Subscribe'}
    </button>
  </form>
  <p class="newsletter-help">Opens your mail client — one-click send, no signup forms.</p>
  <p class="newsletter-incentive">{finalIncentive}</p>
</div>

<style>
  .newsletter {
    margin: 24px 0;
    padding: 20px 22px;
    border-radius: 8px;
    background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 100%);
    border: 1px solid #bae6fd;
  }
  .newsletter-hero {
    padding: 32px 28px;
    margin: 32px 0;
    text-align: center;
    background: linear-gradient(135deg, #1e40af 0%, #3b82f6 100%);
    color: white;
    border: none;
  }
  .newsletter-hero .newsletter-headline,
  .newsletter-hero .newsletter-subheadline {
    color: white;
  }
  .newsletter-hero .newsletter-subheadline {
    color: rgba(255, 255, 255, 0.9);
  }
  .newsletter-footer {
    background: #f8fafc;
    border-color: #e2e8f0;
    padding: 18px 20px;
    text-align: center;
  }
  .newsletter-text {
    margin-bottom: 14px;
  }
  .newsletter-headline {
    margin: 0 0 6px;
    font-size: 1.15rem;
    color: #0c4a6e;
  }
  .newsletter-hero .newsletter-headline {
    font-size: 1.6rem;
  }
  .newsletter-subheadline {
    margin: 0;
    font-size: 0.95rem;
    color: #075985;
    line-height: 1.5;
  }
  .newsletter-form {
    display: flex;
    gap: 8px;
    max-width: 460px;
    margin: 0 auto;
    flex-wrap: wrap;
  }
  .newsletter-hero .newsletter-form {
    max-width: 480px;
  }
  .newsletter-input {
    flex: 1;
    min-width: 220px;
    padding: 11px 14px;
    border: 1px solid #cbd5e1;
    border-radius: 6px;
    font-size: 0.95rem;
    background: white;
    color: var(--c-text);
  }
  .newsletter-hero .newsletter-input {
    background: rgba(255, 255, 255, 0.95);
    color: #1e293b;
  }
  .newsletter-input:focus {
    outline: 2px solid var(--c-accent);
    outline-offset: 1px;
    border-color: var(--c-accent);
  }
  .newsletter-button {
    background: var(--c-accent);
    color: white;
    border: none;
    padding: 11px 22px;
    border-radius: 6px;
    font-weight: 600;
    font-size: 0.95rem;
    cursor: pointer;
    transition: background 0.15s ease;
    white-space: nowrap;
  }
  .newsletter-hero .newsletter-button {
    background: white;
    color: #1e40af;
  }
  .newsletter-button:hover {
    background: #1d4ed8;
  }
  .newsletter-hero .newsletter-button:hover {
    background: #f1f5f9;
  }
  .newsletter-incentive {
    margin: 10px 0 0;
    font-size: 0.82rem;
    color: #475569;
    text-align: center;
  }
  .newsletter-hero .newsletter-incentive {
    color: rgba(255, 255, 255, 0.85);
  }
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
  @media (max-width: 640px) {
    .newsletter-form {
      flex-direction: column;
    }
    .newsletter-input {
      min-width: 100%;
    }
    .newsletter-button {
      width: 100%;
    }
  }
</style>
