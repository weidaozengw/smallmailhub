---
interface Props {
  title: string;
  description: string;
  canonical?: string;
  /** Optional path-prefixed OG image override, e.g. 'mailerlite' or 'default'. Falls back to 'default'. */
  ogImage?: string;
}

const { title, description, canonical, ogImage } = Astro.props;
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, Astro.site).toString();
const year = new Date().getFullYear();

// GA4 — set PUBLIC_GA4_ID env var in Cloudflare Pages to enable
const ga4Id = import.meta.env.PUBLIC_GA4_ID || '';

// Search Console verification meta tag — set PUBLIC_GSC_VERIFICATION env var
const gscVerification = import.meta.env.PUBLIC_GSC_VERIFICATION || '';

// OG image — default to site-wide, allow per-page override
const ogImageName = ogImage ?? 'default';
const ogImageUrl = new URL(`/og/${ogImageName}.png`, Astro.site).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <title>{title}</title>
    {gscVerification && <meta name="google-site-verification" content={gscVerification} />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="article" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="pinterest-rich-pin" content="true" />
    <meta name="twitter:image:alt" content={title} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    {ga4Id && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${ga4Id}`}></script>
        <script is:inline define:vars={{ ga4Id }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', ga4Id, { send_page_view: true });

          // CTA click tracking + outbound link auto-tracking
          document.addEventListener('click', function(e) {
            var el = e.target.closest && e.target.closest('a[href], button[type="submit"]');
            if (!el) return;
            var href = el.href || '';
            var isOutbound = href && href.indexOf(location.host) === -1 && href.indexOf('mailto:') !== 0;
            var isCta = el.classList && el.classList.contains('cta-btn');
            var newsletterForm = el.classList && el.classList.contains('newsletter-button');

            if (isCta) {
              gtag('event', 'cta_click', {
                cta_location: el.closest('.cta-top, .cta-inline, .cta-footer') ? 'review' : 'unknown',
                cta_text: (el.textContent || '').trim().slice(0, 60),
                cta_url: href,
                cta_outbound: isOutbound,
                page_path: location.pathname,
              });
            } else if (isOutbound) {
              // Auto-tag any outbound link (catches UTM-bearing affiliate clicks)
              gtag('event', 'outbound_click', {
                outbound_url: href,
                link_text: (el.textContent || '').trim().slice(0, 60),
                page_path: location.pathname,
              });
            }
          }, true);

          // Newsletter form submit tracking
          document.addEventListener('submit', function(e) {
            var form = e.target;
            if (!form || !form.classList || !form.classList.contains('newsletter-form')) return;
            var variant = form.querySelector('[name="source"]')?.value || 'unknown';
            gtag('event', 'newsletter_submit', {
              newsletter_variant: variant,
              page_path: location.pathname,
            });
          }, true);
        </script>
      </>
    )}

    <style>
      :root {
        --c-bg: #ffffff;
        --c-text: #1a1a1a;
        --c-muted: #555;
        --c-border: #e5e5e5;
        --c-accent: #2563eb;
        --c-warning: #b45309;
        --max-w: 760px;
      }
      * { box-sizing: border-box; }
      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        line-height: 1.65;
        color: var(--c-text);
        background: var(--c-bg);
        margin: 0;
        padding: 0;
      }
      .container { max-width: var(--max-w); margin: 0 auto; padding: 0 20px; }
      header.site {
        border-bottom: 1px solid var(--c-border);
        padding: 18px 0;
      }
      header.site .container { display: flex; align-items: center; justify-content: space-between; }
      .logo { font-weight: 700; font-size: 1.25rem; text-decoration: none; color: var(--c-text); }
      nav.primary a { margin-left: 18px; color: var(--c-muted); text-decoration: none; font-size: 0.95rem; }
      nav.primary a:hover { color: var(--c-accent); }
      main { padding: 40px 0; }
      h1 { font-size: 2rem; line-height: 1.2; margin: 0 0 16px; }
      h2 { font-size: 1.4rem; margin: 36px 0 12px; }
      h3 { font-size: 1.15rem; margin: 24px 0 8px; }
      p { margin: 0 0 16px; }
      a { color: var(--c-accent); }
      ul, ol { padding-left: 22px; }
      li { margin-bottom: 6px; }
      .meta { color: var(--c-muted); font-size: 0.9rem; margin-bottom: 24px; }
      .callout {
        background: #fff7ed;
        border-left: 4px solid var(--c-warning);
        padding: 14px 18px;
        margin: 20px 0;
        border-radius: 4px;
        font-size: 0.95rem;
      }
      .cta {
        display: inline-block;
        background: var(--c-accent);
        color: white;
        padding: 12px 22px;
        border-radius: 6px;
        text-decoration: none;
        font-weight: 600;
        margin: 12px 0;
      }
      .cta:hover { background: #1d4ed8; }
      footer.site {
        border-top: 1px solid var(--c-border);
        padding: 28px 0;
        margin-top: 60px;
        color: var(--c-muted);
        font-size: 0.9rem;
        text-align: center;
      }
      footer.site a { color: var(--c-muted); margin: 0 8px; }
    </style>
  </head>
  <body>
    <header class="site">
      <div class="container">
        <a href="/" class="logo">MailPilot</a>
        <nav class="primary">
          <a href="/">Home</a>
          <a href="/reviews/">Reviews</a>
          <a href="/alternatives/">Alternatives</a>
          <a href="/best/">Best Of</a>
          <a href="/about/">About</a>
        </nav>
      </div>
    </header>
    <main>
      <div class="container">
        <slot />
      </div>
    </main>
    <footer class="site">
      <div class="container">
        <p>&copy; {year} MailPilot. Independent email marketing tool reviews for small businesses.</p>
        <p><a href="/privacy/">Privacy</a> · <a href="/disclosure/">Affiliate Disclosure</a> · <a href="/contact/">Contact</a></p>
      </div>
    </footer>
  </body>
</html>